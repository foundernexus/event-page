        "selector": "JSXOpeningElement[name.name='SiteNavLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<SiteNavLink> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpeakerCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:photo|name|role|company|topic|event|topics|onClick|className|style|key|ref|className|style|children)$/]",
        "message": "<SpeakerCard> doesn't accept that prop. Declared props: photo, name, role, company, topic, event, topics, onClick, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|sublabel|icon|trend|className|style|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, sublabel, icon, trend, className, style."
      },
